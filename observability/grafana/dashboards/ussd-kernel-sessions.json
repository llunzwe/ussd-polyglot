{
  "dashboard": {
    "id": null,
    "uid": "ussd-sessions",
    "title": "USSD Kernel - Sessions",
    "tags": ["ussd", "sessions"],
    "timezone": "utc",
    "schemaVersion": 38,
    "refresh": "15s",
    "panels": [
      {
        "id": 1,
        "title": "Session Reconstruction P99",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum by (le) (rate(session_reconstruct_duration_seconds_bucket[5m])))",
            "legendFormat": "p99"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Cache Hit Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(session_cache_hits_total[5m]) / (rate(session_cache_hits_total[5m]) + rate(session_cache_misses_total[5m]))",
            "legendFormat": "hit rate"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Event Replay Latency",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum by (le) (rate(session_reconstruct_duration_seconds_bucket[5m])))",
            "legendFormat": "replay p99"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Hash Verification Failures",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(session_hash_verification_failures_total[5m])",
            "legendFormat": "failures/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "Active Sessions by Tenant",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum by (tenant_id) (session_active_sessions)",
            "legendFormat": "{{tenant_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}
      }
    ]
  }
}
